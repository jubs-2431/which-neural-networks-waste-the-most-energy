{
  "paper": "Latency, Not FLOPs, Predicts Inference Energy on Apple Silicon",
  "benchmark_scope": {
    "device_family": "Apple Silicon",
    "device_label_in_source": "Apple MacBook Pro (Apple Silicon)",
    "execution_mode": "CPU-only PyTorch inference",
    "input_shape": "1x3x224x224",
    "power_measurement": "powermetrics, 1 Hz",
    "measurement_granularity_note": "Per-inference energy is derived from window-level power sampling because individual inference latencies are shorter than the 1 Hz sampling interval."
  },
  "source_files": {
    "measured_benchmark_csv": "paper_apple_silicon_benchmark.csv",
    "synthetic_alignment_csv": "paper_alignment_comparison.csv",
    "supplemental_power_spread_csv": "paper_alignment_power_std_comparison.csv",
    "data_appendix": "PAPER_DATA_APPENDIX.md"
  },
  "software_requirements": {
    "torch": ">=2.0.0",
    "numpy": ">=1.24.0",
    "pandas": ">=2.0.0",
    "scikit_learn": ">=1.3.0",
    "scipy": ">=1.11.0"
  },
  "gan_workflow_defaults": {
    "seed": 42,
    "latent_dim": 64,
    "hidden_dim": 256,
    "generator_residual_blocks": 3,
    "critic_hidden_layers": 4,
    "critic_spectral_norm": true,
    "critic_dropout": 0.2,
    "batch_size": 64,
    "learning_rate_generator": 0.0001,
    "learning_rate_critic": 0.0001,
    "adam_betas": [0.0, 0.9],
    "critic_updates_per_generator_update": 5,
    "gradient_penalty_lambda": 10.0,
    "default_epochs": 2000,
    "rows_per_combo": 64
  },
  "predictor_checks": {
    "n_models": 5,
    "pearson": {
      "latency_ms": 0.999995,
      "flops_g": -0.008746,
      "parameters_m": 0.23394
    },
    "r_squared": {
      "latency_ms": 0.99999,
      "flops_g": 0.00008,
      "parameters_m": 0.05473
    },
    "spearman": {
      "latency_ms": 1.0,
      "flops_g": 0.6,
      "parameters_m": 0.7
    },
    "leave_one_out_r_squared_range": {
      "latency_ms": [0.99997, 0.999999],
      "flops_g": [0.02794, 0.20694],
      "parameters_m": [0.00030, 0.49447]
    }
  },
  "known_reproducibility_gaps": [
    "Exact original benchmark Python, PyTorch, torchvision, macOS, chip, and power-sampling minor versions should be logged in a future measured benchmark release.",
    "Synthetic trial-spread values are calibrated support estimates, not independently validated physical repeated-trial measurements.",
    "Generated samples and checkpoint files are derived artifacts and may be regenerated from the workflow."
  ]
}
